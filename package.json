{
  "name": "helm-apps",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "0.1.2",
  "publisher": "alvnukov",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:yaml",
    "onView:helmAppsValuesStructure",
    "onView:helmAppsWorkbenchActions",
    "onCommand:helm-apps.configureSchema",
    "onCommand:helm-apps.validateCurrentFile",
    "onCommand:helm-apps.revealValuesNode",
    "onCommand:helm-apps.extractToGlobalInclude",
    "onCommand:helm-apps.safeRenameAppKey",
    "onCommand:helm-apps.previewResolvedEntity",
    "onCommand:helm-apps.goToIncludeDefinition",
    "onCommand:helm-apps.openLibrarySettings",
    "onCommand:helm-apps.generateLibraryHelp",
    "onCommand:helm-apps.findUsages",
    "onCommand:helm-apps.openDependencyGraph",
    "onCommand:helm-apps.pasteAsHelmApps",
    "onCommand:helm-apps.createStarterChart",
    "onCommand:helm-apps.manageLibrarySource",
    "onCommand:helm-apps.checkLibraryUpdate",
    "onCommand:helm-apps.cacheLibraryFromGithub",
    "onCommand:helm-apps.updateLibraryDependency",
    "onCommand:helm-apps.updateLibraryLockfile"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "helmAppsWorkbench",
          "title": "%view.workbench.container.name%",
          "icon": "media/helm-apps-activity.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "helm-apps.configureSchema",
        "title": "%cmd.configureSchema.title%"
      },
      {
        "command": "helm-apps.validateCurrentFile",
        "title": "%cmd.validateCurrentFile.title%"
      },
      {
        "command": "helm-apps.revealValuesNode",
        "title": "%cmd.revealValuesNode.title%"
      },
      {
        "command": "helm-apps.extractToGlobalInclude",
        "title": "%cmd.extractToGlobalInclude.title%"
      },
      {
        "command": "helm-apps.safeRenameAppKey",
        "title": "%cmd.safeRenameAppKey.title%"
      },
      {
        "command": "helm-apps.previewResolvedEntity",
        "title": "%cmd.previewResolvedEntity.title%"
      },
      {
        "command": "helm-apps.goToIncludeDefinition",
        "title": "%cmd.goToIncludeDefinition.title%"
      },
      {
        "command": "helm-apps.openLibrarySettings",
        "title": "%cmd.openLibrarySettings.title%"
      },
      {
        "command": "helm-apps.generateLibraryHelp",
        "title": "%cmd.generateLibraryHelp.title%"
      },
      {
        "command": "helm-apps.findUsages",
        "title": "%cmd.findUsages.title%"
      },
      {
        "command": "helm-apps.openDependencyGraph",
        "title": "%cmd.openDependencyGraph.title%"
      },
      {
        "command": "helm-apps.pasteAsHelmApps",
        "title": "%cmd.pasteAsHelmApps.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsStateless",
        "title": "%cmd.insertEntityTemplate.appsStateless.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsStateful",
        "title": "%cmd.insertEntityTemplate.appsStateful.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsJobs",
        "title": "%cmd.insertEntityTemplate.appsJobs.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsCronjobs",
        "title": "%cmd.insertEntityTemplate.appsCronjobs.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsServices",
        "title": "%cmd.insertEntityTemplate.appsServices.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsIngresses",
        "title": "%cmd.insertEntityTemplate.appsIngresses.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsNetworkPolicies",
        "title": "%cmd.insertEntityTemplate.appsNetworkPolicies.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsConfigmaps",
        "title": "%cmd.insertEntityTemplate.appsConfigmaps.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsSecrets",
        "title": "%cmd.insertEntityTemplate.appsSecrets.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsPvcs",
        "title": "%cmd.insertEntityTemplate.appsPvcs.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsLimitRange",
        "title": "%cmd.insertEntityTemplate.appsLimitRange.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsCertificates",
        "title": "%cmd.insertEntityTemplate.appsCertificates.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsDexClients",
        "title": "%cmd.insertEntityTemplate.appsDexClients.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsDexAuthenticators",
        "title": "%cmd.insertEntityTemplate.appsDexAuthenticators.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsCustomPrometheusRules",
        "title": "%cmd.insertEntityTemplate.appsCustomPrometheusRules.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsGrafanaDashboards",
        "title": "%cmd.insertEntityTemplate.appsGrafanaDashboards.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsKafkaStrimzi",
        "title": "%cmd.insertEntityTemplate.appsKafkaStrimzi.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsInfra",
        "title": "%cmd.insertEntityTemplate.appsInfra.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsServiceAccounts",
        "title": "%cmd.insertEntityTemplate.appsServiceAccounts.title%"
      },
      {
        "command": "helm-apps.insertEntityTemplate.appsK8sManifests",
        "title": "%cmd.insertEntityTemplate.appsK8sManifests.title%"
      },
      {
        "command": "helm-apps.createStarterChart",
        "title": "%cmd.createStarterChart.title%"
      },
      {
        "command": "helm-apps.manageLibrarySource",
        "title": "%cmd.manageLibrarySource.title%"
      },
      {
        "command": "helm-apps.checkLibraryUpdate",
        "title": "%cmd.checkLibraryUpdate.title%"
      },
      {
        "command": "helm-apps.cacheLibraryFromGithub",
        "title": "%cmd.cacheLibraryFromGithub.title%"
      },
      {
        "command": "helm-apps.updateLibraryDependency",
        "title": "%cmd.updateLibraryDependency.title%"
      },
      {
        "command": "helm-apps.updateLibraryLockfile",
        "title": "%cmd.updateLibraryLockfile.title%"
      }
    ],
    "submenus": [
      {
        "id": "helm-apps.insertEntityTemplateSubmenu",
        "label": "%submenu.insertEntityTemplate.label%"
      }
    ],
    "views": {
      "helmAppsWorkbench": [
        {
          "id": "helmAppsWorkbenchActions",
          "name": "%view.workbench.actions.name%"
        }
      ],
      "explorer": [
        {
          "id": "helmAppsValuesStructure",
          "name": "%view.valuesStructure.name%"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "helm-apps.extractToGlobalInclude",
          "when": "resourceLangId == yaml",
          "group": "navigation@50"
        },
        {
          "command": "helm-apps.safeRenameAppKey",
          "when": "resourceLangId == yaml",
          "group": "navigation@51"
        },
        {
          "command": "helm-apps.previewResolvedEntity",
          "when": "resourceLangId == yaml",
          "group": "navigation@52"
        },
        {
          "command": "helm-apps.goToIncludeDefinition",
          "when": "resourceLangId == yaml",
          "group": "navigation@53"
        },
        {
          "command": "helm-apps.openLibrarySettings",
          "when": "resourceLangId == yaml",
          "group": "navigation@54"
        },
        {
          "command": "helm-apps.generateLibraryHelp",
          "when": "resourceLangId == yaml",
          "group": "navigation@55"
        },
        {
          "command": "helm-apps.findUsages",
          "when": "resourceLangId == yaml",
          "group": "navigation@56"
        },
        {
          "command": "helm-apps.openDependencyGraph",
          "when": "resourceLangId == yaml",
          "group": "navigation@57"
        },
        {
          "command": "helm-apps.pasteAsHelmApps",
          "when": "helmApps.happAvailable && resourceLangId == yaml",
          "group": "navigation@58"
        },
        {
          "submenu": "helm-apps.insertEntityTemplateSubmenu",
          "when": "resourceLangId == yaml && helmApps.insertEntityTemplate.visible",
          "group": "navigation@59"
        },
        {
          "command": "helm-apps.updateLibraryDependency",
          "when": "resourceLangId == yaml",
          "group": "navigation@60"
        },
        {
          "command": "helm-apps.updateLibraryLockfile",
          "when": "resourceLangId == yaml",
          "group": "navigation@61"
        }
      ],
      "explorer/context": [
        {
          "command": "helm-apps.createStarterChart",
          "when": "explorerResourceIsFolder",
          "group": "navigation@58"
        }
      ],
      "view/title": [
        {
          "command": "helm-apps.createStarterChart",
          "when": "view == helmAppsWorkbenchActions",
          "group": "navigation@10"
        },
        {
          "command": "helm-apps.previewResolvedEntity",
          "when": "view == helmAppsWorkbenchActions",
          "group": "navigation@11"
        },
        {
          "command": "helm-apps.validateCurrentFile",
          "when": "view == helmAppsWorkbenchActions",
          "group": "navigation@12"
        },
        {
          "command": "helm-apps.openLibrarySettings",
          "when": "view == helmAppsWorkbenchActions",
          "group": "navigation@13"
        },
        {
          "command": "helm-apps.manageLibrarySource",
          "when": "view == helmAppsWorkbenchActions",
          "group": "navigation@14"
        },
        {
          "command": "helm-apps.updateLibraryDependency",
          "when": "view == helmAppsWorkbenchActions",
          "group": "navigation@15"
        },
        {
          "command": "helm-apps.updateLibraryLockfile",
          "when": "view == helmAppsWorkbenchActions",
          "group": "navigation@16"
        }
      ],
      "helm-apps.insertEntityTemplateSubmenu": [
        {
          "command": "helm-apps.insertEntityTemplate.appsStateless",
          "when": "helmApps.insertEntityTemplate.appsStateless"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsStateful",
          "when": "helmApps.insertEntityTemplate.appsStateful"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsJobs",
          "when": "helmApps.insertEntityTemplate.appsJobs"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsCronjobs",
          "when": "helmApps.insertEntityTemplate.appsCronjobs"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsServices",
          "when": "helmApps.insertEntityTemplate.appsServices"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsIngresses",
          "when": "helmApps.insertEntityTemplate.appsIngresses"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsNetworkPolicies",
          "when": "helmApps.insertEntityTemplate.appsNetworkPolicies"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsConfigmaps",
          "when": "helmApps.insertEntityTemplate.appsConfigmaps"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsSecrets",
          "when": "helmApps.insertEntityTemplate.appsSecrets"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsPvcs",
          "when": "helmApps.insertEntityTemplate.appsPvcs"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsLimitRange",
          "when": "helmApps.insertEntityTemplate.appsLimitRange"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsCertificates",
          "when": "helmApps.insertEntityTemplate.appsCertificates"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsDexClients",
          "when": "helmApps.insertEntityTemplate.appsDexClients"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsDexAuthenticators",
          "when": "helmApps.insertEntityTemplate.appsDexAuthenticators"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsCustomPrometheusRules",
          "when": "helmApps.insertEntityTemplate.appsCustomPrometheusRules"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsGrafanaDashboards",
          "when": "helmApps.insertEntityTemplate.appsGrafanaDashboards"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsKafkaStrimzi",
          "when": "helmApps.insertEntityTemplate.appsKafkaStrimzi"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsInfra",
          "when": "helmApps.insertEntityTemplate.appsInfra"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsServiceAccounts",
          "when": "helmApps.insertEntityTemplate.appsServiceAccounts"
        },
        {
          "command": "helm-apps.insertEntityTemplate.appsK8sManifests",
          "when": "helmApps.insertEntityTemplate.appsK8sManifests"
        }
      ]
    },
    "configuration": {
      "title": "%cfg.title%",
      "properties": {
        "helm-apps.schemaFileMatch": {
          "type": "array",
          "default": [],
          "description": "%cfg.schemaFileMatch.description%"
        },
        "helm-apps.happPath": {
          "type": "string",
          "default": "happ",
          "description": "%cfg.happPath.description%"
        },
        "helm-apps.languageServerMode": {
          "type": "string",
          "enum": [
            "happ",
            "fallback"
          ],
          "default": "happ",
          "description": "%cfg.languageServerMode.description%"
        },
        "helm-apps.happLspArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "lsp"
          ],
          "description": "%cfg.happLspArgs.description%"
        },
        "helm-apps.disableYamlSchemaHover": {
          "type": "boolean",
          "default": true,
          "description": "%cfg.disableYamlSchemaHover.description%"
        },
        "helm-apps.librarySource": {
          "type": "string",
          "enum": [
            "local",
            "github"
          ],
          "default": "local",
          "description": "%cfg.librarySource.description%"
        },
        "helm-apps.libraryLocalChartPath": {
          "type": "string",
          "default": "",
          "description": "%cfg.libraryLocalChartPath.description%"
        },
        "helm-apps.libraryGithubRepo": {
          "type": "string",
          "default": "https://github.com/alvnukov/helm-apps.git",
          "description": "%cfg.libraryGithubRepo.description%"
        },
        "helm-apps.libraryRepositoryUrl": {
          "type": "string",
          "default": "https://github.com/alvnukov/helm-apps.git",
          "description": "%cfg.libraryRepositoryUrl.description%"
        },
        "helm-apps.libraryGithubCachedChartPath": {
          "type": "string",
          "default": "",
          "description": "%cfg.libraryGithubCachedChartPath.description%"
        },
        "helm-apps.libraryGithubCachedVersion": {
          "type": "string",
          "default": "",
          "description": "%cfg.libraryGithubCachedVersion.description%"
        },
        "helm-apps.helmPath": {
          "type": "string",
          "default": "helm",
          "description": "%cfg.helmPath.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "npm run sync:library && tsc -p .",
    "watch": "tsc -w -p .",
    "package": "npm run build && vsce package",
    "sync:library": "node ./scripts/sync-bundled-library.js",
    "generate:hover-docs": "node ./scripts/generate-hover-doc-links.js",
    "check:hover-docs": "node ./scripts/check-hover-doc-links.js",
    "test": "tsc -p . && node --test out/test/**/*.test.js && npm run check:hover-docs",
    "test:e2e": "tsc -p . && node ./out/test/e2e/runTest.js"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.16.5",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^10.8.2",
    "typescript": "^5.6.2"
  }
}
