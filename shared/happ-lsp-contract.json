{
  "version": 2,
  "transport": "stdio-jsonrpc",
  "entrypoint": {
    "command": "happ",
    "args": [
      "lsp"
    ],
    "parentPidArg": "--parent-pid=<pid>"
  },
  "methods": {
    "resolveEntity": "happ/resolveEntity",
    "renderEntityManifest": "happ/renderEntityManifest",
    "getPreviewTheme": "happ/getPreviewTheme",
    "optimizeValuesIncludes": "happ/optimizeValuesIncludes"
  },
  "renderEntityManifest": {
    "request": {
      "uri": "string?",
      "text": "string?",
      "group": "string",
      "app": "string",
      "env": "string?",
      "applyIncludes": "boolean?",
      "applyEnvResolution": "boolean?"
    },
    "response": {
      "manifest": "string",
      "defaultEnv": "string",
      "usedEnv": "string",
      "envDiscovery": {
        "literals": "string[]",
        "regexes": "string[]"
      }
    }
  },
  "optimizeValuesIncludes": {
    "request": {
      "uri": "string?",
      "text": "string?",
      "minProfileBytes": "number?"
    },
    "response": {
      "optimizedText": "string",
      "profilesAdded": "number",
      "changed": "boolean"
    }
  }
}
