{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}",
        "--disable-extension",
        "github.copilot",
        "--disable-extension",
        "github.copilot-chat"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "env": {
        "HELM_APPS_DEV_HAPP_PATH": "/Users/zol/src/happ/target/debug/happ"
      },
      "preLaunchTask": "build extension + happ (debug)"
    }
  ]
}
